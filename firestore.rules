rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection: Sales ---
    match /sales/{saleId} {
      // allow list queries only if resource fields are explicitly filtered by the authenticated user's ID
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // allow fetching a single document only if the user owns it
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // allow creating a sale with strict schema and format verification
      allow create: if isSignedIn() 
        && isValidId(saleId)
        && isValidSale(request.resource.data);

      // allow updates only on non-identity fields with exact schema checks
      allow update: if isSignedIn()
        && isValidId(saleId)
        && isValidSale(request.resource.data)
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'item', 'createdAt', 'paymentMethod']);

      // allow deletions only by the owner
      allow delete: if isSignedIn()
        && isValidId(saleId)
        && resource.data.userId == request.auth.uid;
    }

    // Validation helper for Sale document payload
    function isValidSale(data) {
      return data.keys().hasAll(['amount', 'item', 'createdAt', 'paymentMethod', 'userId'])
        && data.keys().size() == 5
        && data.amount is number
        && data.amount >= 0
        && data.item is string
        && data.item.size() > 0
        && data.item.size() <= 200
        && data.createdAt is string
        && data.createdAt.size() <= 50
        && data.paymentMethod is string
        && data.paymentMethod.size() <= 50
        && data.userId is string
        && data.userId == request.auth.uid;
    }
  }
}
